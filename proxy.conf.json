// proxy.conf.json
// Für lokale Entwicklung: ng serve leitet API-Calls an ESP32 weiter
// Verwendung: ng serve --proxy-config proxy.conf.json
{
  "/events": {
    "target": "http://myhome.local",
    "secure": false,
    "changeOrigin": true,
    "headers": {
      "Accept": "text/event-stream"
    }
  },
  "/led": {
    "target": "http://myhome.local",
    "secure": false,
    "changeOrigin": true
  }
}
